{
  "coc.preferences.formatOnSaveFiletypes": ["css", "typescriptreact", "typescript", "rust", "haskell"],
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.diagnostics.disabled": ["incorrect-ident-case"],
  "rust-analyzer.enable": true,
  "languageserver": {
    "haskell": {
      "command": "haskell-language-server-wrapper",
      "args": [
        "--lsp"
      ],
      "rootPatterns": [
        ".stack.yaml",
        ".hie-bios",
        "BUILD.bazel",
        "cabal.config",
        "package.yaml"
      ],
      "filetypes": [
        "hs",
        "lhs",
        "haskell"
      ]
    }
  },
  "cSpell.userWords": [
    "Bibimbap",
    "Darkholme",
